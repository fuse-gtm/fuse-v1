{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript"],
  "categories": {
    "correctness": "off"
  },
  "ignorePatterns": ["node_modules", "dist", ".twenty"],
  "rules": {
    "no-unused-vars": "off",
    "typescript/no-unused-vars": [
      "warn",
      {
        "argsIgnorePattern": "^_"
      }
    ],
    "typescript/no-explicit-any": "off"
  }
}
