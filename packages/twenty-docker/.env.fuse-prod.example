# Custom image built from this repository/branch
TWENTY_IMAGE=ghcr.io/fuse-gtm/fuse-v1:partner-os-latest
TWENTY_IMAGE_PLATFORM=linux/amd64

# Core app URLs/secrets
SERVER_URL=https://app.your-domain.com
# Optional frontend host used for multi-workspace URL generation.
# Example: SERVER_URL=https://app.fusegtm.com and FRONTEND_URL=https://fusegtm.com
FRONTEND_URL=
APP_SECRET=replace_with_openssl_rand_base64_32
PUBLIC_BASE_URL=https://app.your-domain.com
# Optional explicit override; defaults to ${PUBLIC_BASE_URL}/healthz
PUBLIC_HEALTHCHECK_URL=
# When true, deploy script validates public URL after local health.
# Keep true in production. Set false only with a documented break-glass incident override.
VERIFY_PUBLIC_URL=true
# Safety rail: deploy fails if public verification is disabled unless this is true.
# Keep false in production unless you are intentionally bypassing ingress checks.
ALLOW_DEPLOY_WITHOUT_PUBLIC_HEALTHCHECK=false

# Optional: GHCR credentials for private image pulls (read:packages scope)
# GHCR_USERNAME=your-github-username
# GHCR_TOKEN=ghp_or_pat_with_read_packages

# Multi-workspace defaults
IS_MULTIWORKSPACE_ENABLED=true
IS_WORKSPACE_CREATION_LIMITED_TO_SERVER_ADMINS=true
DEFAULT_SUBDOMAIN=app
IS_CONFIG_VARIABLES_IN_DB_ENABLED=false

# Logging/analytics defaults
TELEMETRY_ENABLED=false
ANALYTICS_ENABLED=false
AI_TELEMETRY_ENABLED=false
ALLOW_REQUESTS_TO_TWENTY_ICONS=false
COMPANY_ENRICHMENT_ENABLED=false
COMPANY_ENRICHMENT_PROVIDER=none
MARKETPLACE_REMOTE_FETCH_ENABLED=false
ADMIN_VERSION_CHECK_ENABLED=false
HELP_CENTER_SEARCH_ENABLED=false
HELP_CENTER_SEARCH_PROVIDER=none
SUPPORT_DRIVER=NONE

# Database / Redis
# For local containers: PG_DATABASE_HOST=db
# For AWS RDS: set host to your RDS endpoint and use docker-compose.aws.yml
PG_DATABASE_NAME=default
PG_DATABASE_USER=postgres
PG_DATABASE_PASSWORD=replace_with_strong_password
PG_DATABASE_HOST=db
PG_DATABASE_PORT=5432
REDIS_URL=redis://redis:6379
DISABLE_DB_MIGRATIONS=
DISABLE_CRON_JOBS_REGISTRATION=true
CRON_REGISTRATION_TIMEOUT_SECONDS=60
CRON_REGISTER_COMMAND_TIMEOUT_MS=5000
REGISTER_CRONS_POST_DEPLOY=true
REGISTER_CRONS_TIMEOUT_SECONDS=90
SERVER_NODE_MAX_OLD_SPACE_MB=1024
WORKER_NODE_MAX_OLD_SPACE_MB=768
# Optional preflight warning threshold for low-memory hosts
CHECK_HOST_FREE_MEM=true
MIN_FREE_MEM_MB=512

# Storage (use S3 in production if possible)
STORAGE_TYPE=local
# STORAGE_TYPE=s3
STORAGE_S3_REGION=
STORAGE_S3_NAME=
STORAGE_S3_ENDPOINT=
# Optional for IAM-user auth. Leave blank when using EC2 instance role.
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=

# OAuth + external providers (enable only after callbacks are configured)
AUTH_GOOGLE_ENABLED=false
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=
AUTH_GOOGLE_CALLBACK_URL=https://app.your-domain.com/auth/google/redirect
AUTH_GOOGLE_APIS_CALLBACK_URL=https://app.your-domain.com/auth/google-apis/get-access-token

AUTH_MICROSOFT_ENABLED=false
AUTH_MICROSOFT_CLIENT_ID=
AUTH_MICROSOFT_CLIENT_SECRET=
AUTH_MICROSOFT_CALLBACK_URL=https://app.your-domain.com/auth/microsoft/redirect
AUTH_MICROSOFT_APIS_CALLBACK_URL=https://app.your-domain.com/auth/microsoft-apis/get-access-token

MESSAGING_PROVIDER_GMAIL_ENABLED=false
CALENDAR_PROVIDER_GOOGLE_ENABLED=false
MESSAGING_PROVIDER_MICROSOFT_ENABLED=false
CALENDAR_PROVIDER_MICROSOFT_ENABLED=false

# AI / LLM (stage-gated: set after partner surfaces are validated)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEFAULT_AI_SPEED_MODEL_ID=
DEFAULT_AI_PERFORMANCE_MODEL_ID=
